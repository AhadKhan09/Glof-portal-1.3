{"step_index":148,"source":"USER_EXPLICIT","type":"USER_INPUT","status":"DONE","created_at":"2026-06-12T06:13:54Z","content":"<USER_REQUEST>\n<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<title>National GLOF Watch â€” Navigation</title>\n\n<link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n<link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n<link href=\"https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;600;700&family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap\" rel=\"stylesheet\">\n<link rel=\"stylesheet\" href=\"https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css\">\n<link rel=\"stylesheet\" href=\"https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.2/css/bootstrap.min.css\">\n\n<style>\n  :root{\n    --navy-950:#050d1c;\n    --navy-900:#0a1830;\n    --navy-850:#0e2040;\n    --navy-800:#15294d;\n    --navy-700:#1d3a6a;\n    --ink-glass:rgba(15,28,52,.62);\n\n    --slate-200:#dde6f5;\n    --slate-300:#c2cfe6;\n    --slate-500:#7c91b8;\n    --slate-600:#5b6f96;\n\n    --amber-300:#ffd98a;\n    --amber-400:#f3b94f;\n    --amber-500:#e0a02f;\n\n    --teal-300:#7af0e4;\n    --teal-400:#3fd9c7;\n\n    --green-500:#3ad17e;\n    --red-500:#ff6464;\n\n    --sidebar-w:340px;\n    --ease-soft: cubic-bezier(.22,.61,.36,1);\n    --ease-snap: cubic-bezier(.65,0,.25,1);\n  }\n\n  *{ box-sizing:border-box; }\n  ::selection{ background:rgba(63,217,199,.25); }\n\n  html,body{\n    height:100%;\n    margin:0;\n    font-family:'Plus Jakarta Sans',sans-serif;\n    background:\n      radial-gradient(ellipse 900px 600px at 15% -10%, rgba(63,217,199,.10), transparent 60%),\n      radial-gradient(ellipse 800px 700px at 110% 10%, rgba(243,185,79,.08), transparent 55%),\n      linear-gradient(165deg,#081225 0%, #04070f 100%);\n    color:var(--slate-300);\n    overflow-x:hidden;\n    -webkit-font-smoothing:antialiased;\n  }\n\n  /* ===================== TOP BAR ===================== */\n  .topbar{\n    position:fixed; top:0; left:0; right:0; height:68px;\n    display:flex; align-items:center; justify-content:space-between;\n    padding:0 22px;\n    background:linear-gradient(180deg, rgba(16,32,62,.92) 0%, rgba(8,17,35,.92) 100%);\n    border-bottom:1px solid rgba(255,255,255,.06);\n    backdrop-filter:blur(10px);\n    box-shadow:0 8px 30px rgba(0,0,0,.4);\n    z-index:1100;\n  }\n  .topbar-left{ display:flex; align-items:center; gap:18px; }\n  .topbar-title{\n    font-family:'Space Grotesk',sans-serif;\n    font-weight:700;\n    font-size:1.5rem;\n    letter-spacing:.04em;\n    background:linear-gradient(135deg,#f4f8ff 30%, var(--teal-300) 75%, var(--amber-300) 130%);\n    -webkit-background-clip:text;\n    background-clip:text;\n    color:transparent;\n    white-space:nowrap;\n  }\n  .topbar-title .glof{\n    background:linear-gradient(135deg, var(--amber-300), var(--amber-500));\n    -webkit-background-clip:text; background-clip:text; color:transparent;\n  }\n\n  .badge-n2{\n    font-family:'Space Grotesk',sans-serif;\n    font-weight:700;\n    font-size:1.05rem;\n    letter-spacing:.1em;\n    color:#06281a;\n    background:linear-gradient(135deg,#5cf0a4,var(--green-500) 65%);\n    padding:7px 18px;\n    border-radius:999px;\n    display:flex; align-items:center; gap:9px;\n    box-shadow:0 0 0 1px rgba(255,255,255,.25) inset, 0 6px 20px rgba(58,209,126,.3);\n  }\n  .badge-n2 .pulse-dot{\n    width:8px; height:8px; border-radius:50%;\n    background:#06281a;\n    position:relative;\n  }\n  .badge-n2 .pulse-dot::after{\n    content:'';\n    position:absolute; inset:0; border-radius:50%;\n    background:#06281a;\n    animation:pulse-ring 1.8s ease-out infinite;\n  }\n\n  /* ===================== HAMBURGER ===================== */\n  .hamburger{\n    --size:48px;\n    width:var(--size); height:var(--size);\n    border-radius:14px;\n    border:1px solid rgba(255,255,255,.08);\n    background:linear-gradient(150deg, rgba(255,255,255,.06), rgba(255,255,255,.01));\n    display:flex; align-items:center; justify-content:center;\n    cursor:pointer;\n    position:relative;\n    flex:none;\n    transition:border-color .35s var(--ease-soft), box-shadow .35s var(--ease-soft), transform .15s ease, background .35s ease;\n    box-shadow:0 4px 16px rgba(0,0,0,.35);\n  }\n  .hamburger:hover{\n    border-color:rgba(243,185,79,.45);\n    box-shadow:0 6px 22px rgba(243,185,79,.18);\n    background:linear-gradient(150deg, rgba(243,185,79,.10), rgba(255,255,255,.02));\n  }\n  .hamburger:active{ transform:scale(.93); }\n\n  .hamburger-icon{\n    width:22px; height:16px;\n    position:relative;\n  }\n  .hamburger-icon span{\n    position:absolute; left:0; right:0; height:2px;\n    border-radius:2px;\n    background:linear-gradient(90deg, var(--amber-300), var(--amber-400));\n    transition:transform .4s var(--ease-snap), opacity .25s ease, width .4s ease;\n  }\n  .hamburger-icon span:nth-child(1){ top:0; }\n  .hamburger-icon span:nth-child(2){ top:7px; width:68%; }\n  .hamburger-icon span:nth-child(3){ top:14px; }\n\n  .hamburger.active .hamburger-icon span:nth-child(1){ top:7px; transform:rotate(45deg); }\n  .hamburger.active .hamburger-icon span:nth-child(2){ opacity:0; width:0; }\n  .hamburger.active .hamburger-icon span:nth-child(3){ top:7px; transform:rotate(-45deg); }\n\n  .hamburger::after{\n    content:'';\n    position:absolute; inset:-1px; border-radius:14px;\n    border:1px solid var(--teal-400);\n    opacity:0; pointer-events:none;\n  }\n  .hamburger.ping::after{ animation:radar-ping .65s ease-out; }\n\n  @keyframes radar-ping{\n    0%{ opacity:.9; transform:scale(1); }\n    100%{ opacity:0; transform:scale(1.75); }\n  }\n  @keyframes pulse-ring{\n    0%{ box-shadow:0 0 0 0 rgba(6,40,26,.5); }\n    100%{ box-shadow:0 0 0 7px rgba(6,40,26,0); }\n  }\n\n  /* ===================== OVERLAY ===================== */\n  .overlay{\n    position:fixed; inset:0;\n    background:rgba(2,6,14,.6);\n    backdrop-filter:blur(3px);\n    opacity:0; visibility:hidden;\n    transition:opacity .45s var(--ease-soft), visibility .45s var(--ease-soft);\n    z-index:1040;\n  }\n  body.menu-open .overlay{ opacity:1; visibility:visible; }\n\n  /* ===================== SIDEBAR ===================== */\n  .sidebar{\n    position:fixed; top:0; left:0; bottom:0;\n    width:var(--sidebar-w);\n    max-width:90vw;\n    background:\n      linear-gradient(180deg, rgba(16,32,62,.55) 0%, rgba(6,12,26,.85) 100%),\n      var(--navy-950);\n    border-right:1px solid rgba(255,255,255,.06);\n    box-shadow:24px 0 60px rgba(0,0,0,.5);\n    transform:translateX(-103%);\n    transition:transform .55s var(--ease-snap);\n    z-index:1050;\n    display:flex; flex-direction:column;\n    overflow:hidden;\n  }\n  body.menu-open .sidebar{ transform:translateX(0); }\n\n  /* signature scan-line on the sidebar edge */\n  .sidebar::after{\n    content:'';\n    position:absolute; top:0; right:0; bottom:0; width:2px;\n    background:linear-gradient(180deg, transparent, var(--teal-300), transparent);\n    opacity:.5;\n    animation:scan-sweep 3.6s ease-in-out infinite;\n    filter:blur(.5px);\n  }\n  @keyframes scan-sweep{\n    0%,100%{ transform:translateY(-100%); opacity:0; }\n    15%{ opacity:.7; }\n    50%{ transform:translateY(100%); opacity:.7; }\n    85%{ opacity:0; }\n  }\n\n  /* ---- header with topographic contour texture ---- */\n  .sidebar-head{\n    position:relative;\n    padding:24px 20px 20px;\n    border-bottom:1px solid rgba(255,255,255,.06);\n    flex:none;\n    overflow:hidden;\n    background:linear-gradient(135deg, rgba(63,217,199,.10), rgba(243,185,79,.05) 70%);\n  }\n  .sidebar-head .contours{\n    position:absolute; inset:0; width:100%; height:100%;\n    opacity:.35; pointer-events:none;\n    mix-blend-mode:screen;\n  }\n  .sidebar-head-row{\n    position:relative; z-index:1;\n    display:flex; align-items:center; justify-content:space-between;\n  }\n  .sidebar-brand{ display:flex; align-items:center; gap:13px; }\n  .sidebar-logo{\n    width:42px; height:42px; border-radius:13px;\n    background:linear-gradient(140deg,#5cf0a4, #1d9e5c 75%);\n    display:flex; align-items:center; justify-content:center;\n    color:#06281a; font-size:1.15rem;\n    box-shadow:0 0 0 1px rgba(255,255,255,.25) inset, 0 6px 18px rgba(58,209,126,.25);\n  }\n  .sidebar-brand-text{ line-height:1.2; }\n  .sidebar-brand-text .b1{\n    font-family:'Space Grotesk',sans-serif; font-weight:700;\n    font-size:1.12rem; color:#f6f9ff; letter-spacing:.03em;\n  }\n  .sidebar-brand-text .b2{\n    font-size:.72rem; color:var(--slate-500); letter-spacing:.18em; text-transform:uppercase;\n    margin-top:2px;\n  }\n  .sidebar-close{\n    width:36px; height:36px; border-radius:10px;\n    border:1px solid rgba(255,255,255,.08);\n    background:rgba(255,255,255,.04);\n    color:var(--slate-300);\n    display:flex; align-items:center; justify-content:center;\n    cursor:pointer; transition:all .3s var(--ease-soft);\n    flex:none;\n  }\n  .sidebar-close:hover{\n    background:rgba(255,100,100,.12); color:var(--red-500); border-color:rgba(255,100,100,.3);\n    transform:rotate(90deg);\n  }\n\n  .sidebar-tagline{\n    position:relative; z-index:1;\n    margin-top:14px;\n    font-size:.78rem; color:var(--slate-500);\n    letter-spacing:.04em;\n    display:flex; align-items:center; gap:8px;\n  }\n  .sidebar-tagline i{ color:var(--teal-400); font-size:.7rem; }\n\n  /* ===================== SCROLL AREA ===================== */\n  .sidebar-scroll{\n    flex:1; overflow-y:auto; padding:16px 14px 24px;\n  }\n  .sidebar-scroll::-webkit-scrollbar{ width:6px; }\n  .sidebar-scroll::-webkit-scrollbar-thumb{ background:rgba(243,185,79,.22); border-radius:4px; }\n  .sidebar-scroll::-webkit-scrollbar-track{ background:transparent; }\n\n  /* ===================== YEAR DIVIDERS ===================== */\n  .year-divider{\n    display:flex; align-items:center; gap:10px;\n    margin:22px 8px 10px;\n    font-family:'Space Grotesk',sans-serif; font-weight:600;\n    font-size:.8rem; letter-spacing:.22em; color:var(--slate-600);\n  }\n  .year-divider:first-child{ margin-top:6px; }\n  .year-divider::after{\n    content:''; flex:1; height:1px;\n    background:linear-gradient(90deg, rgba(255,255,255,.16), transparent);\n  }\n  .year-divider .live-dot{\n    width:8px; height:8px; border-radius:50%; background:var(--red-500);\n    box-shadow:0 0 0 0 rgba(255,100,100,.6);\n    animation:pulse-ring-red 1.6s ease-out infinite;\n  }\n  @keyframes pulse-ring-red{\n    0%{ box-shadow:0 0 0 0 rgba(255,100,100,.5); }\n    100%{ box-shadow:0 0 0 6px rgba(255,100,100,0); }\n  }\n\n  /* ===================== NAV ITEMS ===================== */\n  .nav-item{\n    border-radius:14px;\n    margin:5px 0;\n    overflow:hidden;\n    opacity:0;\n    transform:translateX(-22px);\n    transition:opacity .45s var(--ease-soft), transform .45s var(--ease-soft), background .3s ease;\n  }\n  body.menu-open .nav-item{ opacity:1; transform:translateX(0); }\n\n  .nav-item-head{\n    display:flex; align-items:center; gap:14px;\n    padding:13px 14px;\n    cursor:pointer;\n    position:relative;\n    border-radius:14px;\n    transition:background .3s var(--ease-soft);\n  }\n  .nav-item-head::before{\n    content:'';\n    position:absolute; left:0; top:9px; bottom:9px; width:3px;\n    border-radius:3px;\n    background:linear-gradient(180deg, var(--amber-300), var(--amber-500));\n    transform:scaleY(0);\n    transition:transform .3s var(--ease-soft);\n    transform-origin:center;\n  }\n  .nav-item-head:hover{ background:rgba(255,255,255,.035); }\n  .nav-item-head:hover::before,\n  .nav-item.open .nav-item-head::before{ transform:scaleY(1); }\n  .nav-item.open .nav-item-head{ background:rgba(243,185,79,.06); }\n  .nav-item.open{\n    box-shadow:0 8px 28px -16px rgba(0,0,0,.6), 0 0 0 1px rgba(255,255,255,.04) inset;\n  }\n\n  .nav-icon{\n    width:38px; height:38px; border-radius:11px;\n    display:flex; align-items:center; justify-content:center;\n    background:rgba(255,255,255,.045);\n    border:1px solid rgba(255,255,255,.05);\n    color:var(--amber-300);\n    font-size:1.02rem;\n    flex:none;\n    transition:background .3s var(--ease-soft), color .3s ease, transform .35s var(--ease-soft), border-color .3s ease, box-shadow .3s ease;\n  }\n  .nav-item.open .nav-icon, .nav-item-head:hover .nav-icon{\n    background:rgba(243,185,79,.14); color:var(--amber-300);\n    border-color:rgba(243,185,79,.25);\n    transform:scale(1.07) rotate(-4deg);\n    box-shadow:0 0 18px rgba(243,185,79,.18);\n  }\n  .nav-icon.teal{ color:var(--teal-400); }\n  .nav-item.open .nav-icon.teal, .nav-item-head:hover .nav-icon.teal{\n    background:rgba(63,217,199,.14); color:var(--teal-300);\n    border-color:rgba(63,217,199,.25);\n    box-shadow:0 0 18px rgba(63,217,199,.18);\n  }\n\n  .nav-label{\n    flex:1;\n    font-family:'Space Grotesk',sans-serif; font-weight:600;\n    font-size:1.01rem; letter-spacing:.015em; color:#f3f6fc;\n  }\n  .nav-chevron{\n    color:var(--slate-600); font-size:.78rem;\n    transition:transform .4s var(--ease-snap), color .3s ease;\n  }\n  .nav-item.open .nav-chevron{ transform:rotate(180deg); color:var(--amber-300); }\n\n  .nav-body{\n    display:grid; grid-template-rows:0fr;\n    transition:grid-template-rows .45s var(--ease-snap);\n  }\n  .nav-item.open .nav-body{ grid-template-rows:1fr; }\n  .nav-body-inner{ overflow:hidden; }\n  .nav-sub{\n    padding:6px 14px 14px 64px;\n    display:flex; flex-direction:column; gap:10px;\n  }\n  .sub-row{\n    display:flex; align-items:center; justify-content:space-between;\n    font-size:.87rem; color:var(--slate-300);\n    padding:7px 11px;\n    border-radius:9px;\n    transition:background .25s ease, transform .25s ease;\n    transform:translateX(-10px); opacity:0;\n  }\n  .nav-item.open .sub-row{ animation:sub-in .4s var(--ease-soft) forwards; }\n  .nav-item.open .sub-row:nth-child(1){ animation-delay:.06s; }\n  .nav-item.open .sub-row:nth-child(2){ animation-delay:.13s; }\n  .nav-item.open .sub-row:nth-child(3){ animation-delay:.2s; }\n  @keyframes sub-in{ to{ transform:translateX(0); opacity:1; } }\n  .sub-row:hover{ background:rgba(255,255,255,.04); transform:translateX(3px); }\n\n  /* mini switches inside sub-rows */\n  .mswitch{\n    width:36px; height:19px; border-radius:20px;\n    background:rgba(255,255,255,.08);\n    position:relative; cursor:pointer; flex:none;\n    transition:background .3s ease, border-color .3s ease;\n    border:1px solid rgba(255,255,255,.06);\n  }\n  .mswitch::after{\n    content:''; position:absolute; top:1px; left:1px;\n    width:15px; height:15px; border-radius:50%;\n    background:var(--slate-600);\n    transition:transform .3s var(--ease-snap), background .3s ease;\n  }\n  .mswitch.on{ background:rgba(63,217,199,.2); border-color:rgba(63,217,199,.4); }\n  .mswitch.on::after{ transform:translateX(17px); background:var(--teal-300); box-shadow:0 0 10px rgba(63,217,199,.5); }\n\n  /* ===================== STANDALONE TOGGLE ROW (Satellite Imagery) ===================== */\n  .standalone-row{\n    display:flex; align-items:center; gap:14px;\n    padding:13px 14px; margin:14px 0 6px;\n    border-radius:14px;\n    background:linear-gradient(120deg, rgba(63,217,199,.12), rgba(243,185,79,.07));\n    border:1px solid rgba(63,217,199,.2);\n    cursor:pointer;\n    opacity:0; transform:translateX(-22px);\n    transition:opacity .45s var(--ease-soft), transform .45s var(--ease-soft), box-shadow .3s ease, transform .25s ease;\n  }\n  body.menu-open .standalone-row{ opacity:1; transform:translateX(0); transition-delay:.06s; }\n  .standalone-row:hover{ box-shadow:0 0 26px rgba(63,217,199,.18); transform:translateY(-1px); }\n  .standalone-row .nav-label{ font-size:1rem; }\n\n  /* ===================== LAYER TOUR CARD ===================== */\n  .tour-card{\n    margin:20px 6px 8px;\n    padding:16px;\n    border-radius:16px;\n    background:rgba(255,255,255,.03);\n    border:1px solid rgba(255,255,255,.07);\n    opacity:0; transform:translateY(16px);\n    transition:opacity .55s var(--ease-soft), transform .55s var(--ease-soft);\n    transition-delay:.18s;\n  }\n  body.menu-open .tour-card{ opacity:1; transform:translateY(0); }\n\n  .tour-card-head{\n    display:flex; align-items:center; justify-content:space-between;\n    margin-bottom:12px;\n  }\n  .tour-card-head .nav-label{ font-size:.97rem; display:flex; align-items:center; gap:9px; }\n  .tour-refresh{\n    color:var(--slate-600); cursor:pointer; transition:transform .6s var(--ease-snap), color .3s ease;\n    width:30px; height:30px; border-radius:8px;\n    display:flex; align-items:center; justify-content:center;\n    border:1px solid rgba(255,255,255,.06);\n  }\n  .tour-refresh:hover{ color:var(--amber-300); transform:rotate(180deg); border-color:rgba(243,185,79,.3); }\n\n  .tour-select{\n    width:100%; padding:10px 12px; border-radius:9px;\n    background:rgba(255,255,255,.04); border:1px solid rgba(255,255,255,.08);\n    color:var(--slate-300); font-size:.85rem; margin-bottom:16px;\n    font-family:'Plus Jakarta Sans',sans-serif;\n    transition:border-color .3s ease, background .3s ease;\n    appearance:none;\n  }\n  .tour-select:focus{ outline:none; border-color:var(--teal-400); background:rgba(63,217,199,.05); }\n\n  .tour-speed{ display:flex; align-items:center; gap:12px; margin-bottom:16px; font-size:.78rem; color:var(--slate-500); }\n  .tour-speed input[type=range]{\n    flex:1; -webkit-appearance:none; height:4px; border-radius:4px;\n    background:linear-gradient(90deg, var(--teal-400) 50%, rgba(255,255,255,.1) 50%);\n    outline:none;\n  }\n  .tour-speed input[type=range]::-webkit-slider-thumb{\n    -webkit-appearance:none; width:17px; height:17px; border-radius:50%;\n    background:#fff; cursor:pointer;\n    box-shadow:0 0 0 5px rgba(63,217,199,.2), 0 2px 8px rgba(0,0,0,.3);\n    transition:box-shadow .25s ease;\n  }\n  .tour-speed input[type=range]:hover::-webkit-slider-thumb{ box-shadow:0 0 0 7px rgba(63,217,199,.28), 0 2px 8px rgba(0,0,0,.3); }\n\n  .tour-buttons{ display:flex; gap:10px; }\n  .btn-tour{\n    flex:1; padding:10px; border-radius:10px; font-family:'Space Grotesk',sans-serif;\n    font-weight:600; font-size:.92rem; letter-spacing:.04em;\n    border:1px solid transparent; cursor:pointer;\n    transition:transform .15s ease, box-shadow .3s ease, background .3s ease, filter .3s ease;\n  }\n  .btn-tour:active{ transform:scale(.97); }\n  .btn-start{\n    background:linear-gradient(135deg,#4fa9ff,#2563d4); color:#fff;\n  }\n  .btn-start:hover{ box-shadow:0 6px 20px rgba(79,169,255,.4); filter:brightness(1.08); }\n  .btn-idle{\n    background:rgba(255,255,255,.05); color:var(--slate-500);\n    border-color:rgba(255,255,255,.08);\n  }\n  .btn-idle:hover{ background:rgba(255,255,255,.08); color:var(--slate-300); }\n\n  /* ===================== FOOTER TOGGLE ===================== */\n  .sidebar-foot{\n    flex:none; padding:16px 20px;\n    border-top:1px solid rgba(255,255,255,.06);\n    display:flex; align-items:center; justify-content:space-between;\n    background:rgba(255,255,255,.015);\n  }\n  .foot-label{ display:flex; align-items:center; gap:11px; font-family:'Space Grotesk',sans-serif; font-weight:600; letter-spacing:.03em; color:#f3f6fc; font-size:.95rem; }\n  .foot-label i{ color:var(--slate-600); font-size:.92rem; }\n  .foot-switch{\n    width:48px; height:26px; border-radius:24px;\n    background:rgba(255,255,255,.08);\n    position:relative; cursor:pointer; border:1px solid rgba(255,255,255,.08);\n    transition:background .3s ease, border-color .3s ease;\n  }\n  .foot-switch::after{\n    content:''; position:absolute; top:2px; left:2px;\n    width:20px; height:20px; border-radius:50%;\n    background:var(--slate-600);\n    transition:transform .35s var(--ease-snap), background .3s ease;\n  }\n  .foot-switch.on{ background:rgba(243,185,79,.22); border-color:rgba(243,185,79,.4); }\n  .foot-switch.on::after{ transform:translateX(22px); background:var(--amber-300); box-shadow:0 0 10px rgba(243,185,79,.5); }\n\n  /* responsive */\n  @media (max-width:480px){\n    .topbar-title{ font-size:1.18rem; }\n    :root{ --sidebar-w:90vw; }\n  }\n\n  @media (prefers-reduced-motion: reduce){\n    *{ animation:none !important; transition:none !important; }\n  }\n</style>\n</head>\n<body>\n\n  <!-- TOP BAR -->\n  <header class=\"topbar\">\n    <div class=\"topbar-left\">\n      <button class=\"hamburger\" id=\"hamburgerBtn\" aria-label=\"Open navigation menu\" aria-expanded=\"false\">\n        <div class=\"hamburger-icon\">\n          <span></span><span></span><span></span>\n        </div>\n      </button>\n      <div class=\"topbar-title\">National <span class=\"glof\">GLOF</span> Watch</div>\n    </div>\n    <div class=\"badge-n2\"><span class=\"pulse-dot\"></span> N-2</div>\n  </header>\n\n  <!-- OVERLAY -->\n  <div class=\"overlay\" id=\"overlay\"></div>\n\n  <!-- SIDEBAR -->\n  <nav class=\"sidebar\" id=\"sidebar\" aria-label=\"Main navigation\">\n    <div class=\"sidebar-head\">\n      <!-- topographic contour texture -->\n      <svg class=\"contours\" viewBox=\"0 0 340 160\" preserveAspectRatio=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n        <path d=\"M-10 130 C 40 110, 90 150, 140 120 S 230 80, 300 110 S 380 140, 420 100\" stroke=\"#3fd9c7\" stroke-width=\"1\" fill=\"none\" opacity=\".5\"/>\n        <path d=\"M-10 110 C 50 90, 100 130, 150 100 S 240 60, 310 90 S 390 120, 430 80\" stroke=\"#3fd9c7\" stroke-width=\"1\" fill=\"none\" opacity=\".35\"/>\n        <path d=\"M-10 90 C 60 70, 110 110, 160 80 S 250 40, 320 70 S 400 100, 440 60\" stroke=\"#f3b94f\" stroke-width=\"1\" fill=\"none\" opacity=\".3\"/>\n        <path d=\"M-10 70 C 70 50, 120 90, 170 60 S 260 20, 330 50 S 410 80, 450 40\" stroke=\"#f3b94f\" stroke-width=\"1\" fill=\"none\" opacity=\".2\"/>\n        <path d=\"M-10 150 C 30 135, 80 165, 130 140 S 220 10