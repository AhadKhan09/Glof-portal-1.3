teal\"><i class=\"fa-solid fa-satellite-dish\"></i></div>\n          <div class=\"nav-label\">PMD Sensors</div>\n          <i class=\"fa-solid fa-chevron-down nav-chevron\"></i>\n        </div>\n        <div class=\"nav-body\"><div class=\"nav-body-inner\"><div class=\"nav-sub\">\n          <div class=\"sub-row\"><span>Automatic Weather Stations</span><div class=\"mswitch on\"></div></div>\n          <div class=\"sub-row\"><span>River Gauges</span><div class=\"mswitch\"></div></div>\n          <div class=\"sub-row\"><span>Snow Depth Sensors</span><div class=\"mswitch\"></div></div>\n        </div></div></div>\n      </div>\n\n      <!-- Routes -->\n      <div class=\"nav-item\">\n        <div class=\"nav-item-head\">\n          <div class=\"nav-icon\"><i class=\"fa-solid fa-route\"></i></div>\n          <div class=\"nav-label\">Routes</div>\n          <i class=\"fa-solid fa-chevron-down nav-chevron\"></i>\n        </div>\n        <div class=\"nav-body\"><div class=\"nav-body-inner\"><div class=\"nav-sub\">\n          <div class=\"sub-row\"><span>Evacuation Routes</span><div class=\"mswitch\"></div></div>\n          <div class=\"sub-row\"><span>Highway Network</span><div class=\"mswitch on\"></div></div>\n          <div class=\"sub-row\"><span>Access Tracks</span><div class=\"mswitch\"></div></div>\n        </div></div></div>\n      </div>\n\n      <!-- Risk Zonation -->\n      <div class=\"nav-item\">\n        <div class=\"nav-item-head\">\n          <div class=\"nav-icon\"><i class=\"fa-solid fa-map-location-dot\"></i></div>\n          <div class=\"nav-label\">Risk Zonation</div>\n          <i class=\"fa-solid fa-chevron-down nav-chevron\"></i>\n        </div>\n        <div class=\"nav-body\"><div class=\"nav-body-inner\"><div class=\"nav-sub\">\n          <div class=\"sub-row\"><span>High Hazard Zones</span><div class=\"mswitch on\"></div></div>\n          <div class=\"sub-row\"><span>Moderate Hazard Zones</span><div class=\"mswitch\"></div></div>\n          <div class=\"sub-row\"><span>Settlement Exposure</span><div class=\"mswitch\"></div></div>\n        </div></div></div>\n      </div>\n\n      <!-- Vulnerable Lakes -->\n      <div class=\"nav-item\">\n        <div class=\"nav-item-head\">\n          <div class=\"nav-icon teal\"><i class=\"fa-solid fa-droplet\"></i></div>\n          <div class=\"nav-label\">Vulnerable Lakes</div>\n          <i class=\"fa-solid fa-chevron-down nav-chevron\"></i>\n        </div>\n        <div class=\"nav-body\"><div class=\"nav-body-inner\"><div class=\"nav-sub\">\n          <div class=\"sub-row\"><span>Glacial Lake Inventory</span><div class=\"mswitch on\"></div></div>\n          <div class=\"sub-row\"><span>Outburst Probability</span><div class=\"mswitch\"></div></div>\n          <div class=\"sub-row\"><span>Moraine Stability</span><div class=\"mswitch\"></div></div>\n        </div></div></div>\n      </div>\n\n      <!-- Land Surface Temp -->\n      <div class=\"nav-item\">\n        <div class=\"nav-item-head\">\n          <div class=\"nav-icon\"><i class=\"fa-solid fa-temperature-three-quarters\"></i></div>\n          <div class=\"nav-label\">Land Surface Temp</div>\n          <i class=\"fa-solid fa-chevron-down nav-chevron\"></i>\n        </div>\n        <div class=\"nav-body\"><div class=\"nav-body-inner\"><div class=\"nav-sub\">\n          <div class=\"sub-row\"><span>Daily Mean Temperature</span><div class=\"mswitch\"></div></div>\n          <div class=\"sub-row\"><span>Anomaly vs 10yr Average</span><div class=\"mswitch\"></div></div>\n          <div class=\"sub-row\"><span>Thermal Hotspots</span><div class=\"mswitch\"></div></div>\n        </div></div></div>\n      </div>\n\n      <!-- Satellite Imagery (standalone toggle) -->\n      <div class=\"standalone-row\" id=\"satRow\">\n        <div class=\"nav-icon teal\"><i class=\"fa-solid fa-satellite\"></i></div>\n        <div class=\"nav-label\">Satellite Imagery</div>\n        <div class=\"mswitch on\" id=\"satSwitch\"></div>\n      </div>\n\n      <!-- Layer Tour -->\n      <div class=\"tour-card\">\n        <div class=\"tour-card-head\">\n          <div class=\"nav-label\"><i class=\"fa-solid fa-binoculars\" style=\"color:var(--amber-300)\"></i>Layer Tour</div>\n          <div class=\"tour-refresh\"><i class=\"fa-solid fa-rotate\"></i></div>\n        </div>\n        <select class=\"tour-select\">\n          <option>Select opened layer</option>\n          <option>Vulnerable Lakes</option>\n          <option>Risk Zonation</option>\n          <option>Season Layers 2026</option>\n        </select>\n        <div class=\"tour-speed\">\n          <span>Speed</span>\n          <input type=\"range\" min=\"0\" max=\"100\" value=\"50\">\n          <span>Normal</span>\n        </div>\n        <div class=\"tour-buttons\">\n          <button class=\"btn-tour btn-start\">Start Tour</button>\n          <button class=\"btn-tour btn-idle\">IDLE</button>\n        </div>\n      </div>\n\n    </div>\n\n    <!-- Footer toggle -->\n    <div class=\"sidebar-foot\">\n      <div class=\"foot-label\"><i class=\"fa-solid fa-box-archive\"></i> Alerts Archive</div>\n      <div class=\"foot-switch\" id=\"archiveSwitch\"></div>\n    </div>\n  </nav>\n\n  <script src=\"https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.2/js/bootstrap.bundle.min.js\"></script>\n  <script>\n    const body = document.body;\n    const hamburger = document.getElementById('hamburgerBtn');\n    const overlay = document.getElementById('overlay');\n    const closeBtn = document.getElementById('closeBtn');\n\n    function openMenu(){\n      body.classList.add('menu-open');\n      hamburger.classList.add('active');\n      hamburger.setAttribute('aria-expanded','true');\n    }\n    function closeMenu(){\n      body.classList.remove('menu-open');\n      hamburger.classList.remove('active');\n      hamburger.setAttribute('aria-expanded','false');\n    }\n    function pingHamburger(){\n      hamburger.classList.remove('ping');\n      requestAnimationFrame(()=>{\n        hamburger.classList.add('ping');\n        setTimeout(()=>hamburger.classList.remove('ping'), 700);\n      });\n    }\n\n    hamburger.addEventListener('click', () => {\n      pingHamburger();\n      body.classList.contains('menu-open') ? closeMenu() : openMenu();\n    });\n    closeBtn.addEventListener('click', closeMenu);\n    overlay.addEventListener('click', closeMenu);\n    document.addEventListener('keydown', (e) => {\n      if(e.key === 'Escape') closeMenu();\n    });\n\n    // Accordion: open one nav-item, close others\n    document.querySelectorAll('.nav-item-head').forEach(head => {\n      head.addEventListener('click', () => {\n        const item = head.closest('.nav-item');\n        const isOpen = item.classList.contains('open');\n        document.querySelectorAll('.nav-item.open').forEach(el => el.classList.remove('open'));\n        if(!isOpen) item.classList.add('open');\n      });\n    });\n\n    // mini switches inside sub-rows\n    document.querySelectorAll('.mswitch').forEach(sw => {\n      sw.addEventListener('click', (e) => {\n        e.stopPropagation();\n        sw.classList.toggle('on');\n      });\n    });\n\n    // satellite imagery row\n    document.getElementById('satRow').addEventListener('click', () => {\n      document.getElementById('satSwitch').classList.toggle('on');\n    });\n\n    // footer archive switch\n    document.getElementById('archiveSwitch').addEventListener('click', (e) => {\n      e.currentTarget.classList.toggle('on');\n    });\n  </script>\n</body>\n</html>\n\n\nI want to have this kind of menu bar.\nPlease update the part also which is still missing like animations.\n\nJust stick with the menu bar. Ignore the navbar and other things\n</USER_REQUEST>\n<ADDITIONAL_METADATA>\nThe current local time is: 2026-06-12T11:13:54+05:00.\n</ADDITIONAL_METADATA>"}
