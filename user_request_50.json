ckdrop-filter: blur(8px);\n    border-bottom: 1px solid rgba(255,255,255,0.08);\n    display: flex;\n    align-items: center;\n    padding: 0 16px;\n    gap: 12px;\n    z-index: 100;\n  }\n\n  .globe-icon {\n    width: 36px; height: 36px;\n    border-radius: 50%;\n    background: rgba(255,255,255,0.08);\n    border: 1.5px solid rgba(255,255,255,0.2);\n    display: flex; align-items: center; justify-content: center;\n    flex-shrink: 0;\n  }\n\n  .globe-icon svg { width: 20px; height: 20px; }\n\n  .topbar-title {\n    flex: 1;\n    text-align: center;\n    font-size: 15px;\n    font-weight: 500;\n    color: #e8f4f8;\n    letter-spacing: 0.05em;\n    text-transform: uppercase;\n    font-size: 13px;\n  }\n\n  .badge-n2 {\n    background: #22c55e;\n    color: #052e16;\n    font-size: 12px;\n    font-weight: 600;\n    padding: 4px 10px;\n    border-radius: 4px;\n    letter-spacing: 0.05em;\n  }\n\n  .hamburger-btn {\n    width: 36px; height: 36px;\n    border-radius: 6px;\n    background: rgba(255,255,255,0.07);\n    border: 1px solid rgba(255,255,255,0.12);\n    cursor: pointer;\n    display: flex; align-items: center; justify-content: center;\n    flex-direction: column;\n    gap: 5px;\n    padding: 0;\n    transition: background 0.2s, border-color 0.2s;\n    flex-shrink: 0;\n    outline: none;\n  }\n\n  .hamburger-btn:hover {\n    background: rgba(255,255,255,0.13);\n    border-color: rgba(255,255,255,0.25);\n  }\n\n  .hamburger-btn.active { background: rgba(34,197,94,0.15); border-color: rgba(34,197,94,0.4); }\n\n  .bar {\n    width: 18px; height: 1.5px;\n    background: #d1e8f0;\n    border-radius: 2px;\n    transition: transform 0.35s cubic-bezier(.68,-.55,.27,1.55), opacity 0.25s, width 0.3s;\n    transform-origin: center;\n  }\n\n  .hamburger-btn.active .bar:nth-child(1) { transform: translateY(6.5px) rotate(45deg); }\n  .hamburger-btn.active .bar:nth-child(2) { opacity: 0; width: 0; }\n  .hamburger-btn.active .bar:nth-child(3) { transform: translateY(-6.5px) rotate(-45deg); }\n\n  .sidebar {\n    position: absolute;\n    top: 52px; left: 0; bottom: 0;\n    width: 220px;\n    background: rgba(10,20,35,0.94);\n    backdrop-filter: blur(12px);\n    border-right: 1px solid rgba(255,255,255,0.08);\n    transform: translateX(-100%);\n    transition: transform 0.4s cubic-bezier(.25,.8,.25,1);\n    z-index: 90;\n    overflow-y: auto;\n    overflow-x: hidden;\n  }\n\n  .sidebar.open { transform: translateX(0); }\n\n  .sidebar-overlay {\n    position: absolute;\n    top: 52px; left: 0; bottom: 0; right: 0;\n    background: rgba(0,0,0,0.45);\n    opacity: 0;\n    pointer-events: none;\n    transition: opacity 0.35s;\n    z-index: 80;\n  }\n\n  .sidebar-overlay.visible { opacity: 1; pointer-events: auto; }\n\n  .year-badge {\n    font-size: 10px;\n    font-weight: 600;\n    letter-spacing: 0.08em;\n    color: rgba(255,255,255,0.35);\n    padding: 12px 16px 4px;\n    text-transform: uppercase;\n  }\n\n  .menu-item {\n    display: flex;\n    align-items: center;\n    gap: 10px;\n    padding: 10px 16px;\n    cursor: pointer;\n    transition: background 0.18s;\n    border: none;\n    background: transparent;\n    width: 100%;\n    text-align: left;\n    border-bottom: 0.5px solid rgba(255,255,255,0.04);\n    position: relative;\n    opacity: 0;\n    transform: translateX(-18px);\n    animation: none;\n  }\n\n  .sidebar.open .menu-item {\n    animation: slide-in 0.35s cubic-bezier(.25,.8,.25,1) forwards;\n  }\n\n  .sidebar.open .menu-item:nth-child(1) { animation-delay: 0.04s; }\n  .sidebar.open .menu-item:nth-child(2) { animation-delay: 0.08s; }\n  .sidebar.open .menu-item:nth-child(3) { animation-delay: 0.12s; }\n  .sidebar.open .menu-item:nth-child(4) { animation-delay: 0.16s; }\n  .sidebar.open .menu-item:nth-child(5) { animation-delay: 0.20s; }\n  .sidebar.open .menu-item:nth-child(6) { animation-delay: 0.24s; }\n  .sidebar.open .menu-item:nth-child(7) { animation-delay: 0.28s; }\n  .sidebar.open .menu-item:nth-child(8) { animation-de